generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SPADMIN
}

enum OrderStatus {
  PENDING
  PROCESSING
  ORDER_PLACED
  TRACKING_GENERATED
  DELIVERED
  CANCELED
}

enum TransactionType {
  DEPOSIT
  ORDER_DEBIT
  ADMIN_ADJUSTMENT
  ORDER_REFUND
  WITHDRAWAL
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum NotificationType {
  ORDER_CREATED
  ORDER_COMPLETED
  ORDER_CANCELED
  DEPOSIT_SUCCESS
  BALANCE_CHANGED
  ADMIN_MESSAGE
}

enum CryptoDepositStatus {
  PENDING
  COMPLETED
  EXPIRED
}

enum BankDepositStatus {
  PENDING
  TRANSFERRED
  COMPLETED
  EXPIRED
  COMPLAINED
  REJECTED
}

model User {
  id             Int               @id @default(autoincrement())
  fullName       String            @default("")
  username       String            @unique
  email          String            @unique
  phone          String            @unique
  passwordHash   String
  role           Role              @default(USER)
  balance        Int               @default(0)
  orders         Order[]
  transactions   Transaction[]
  auditLogs      AuditLog[]        @relation("AuditLogAdmin")
  notifications  Notification[]
  withdrawals    Withdrawal[]
  cryptoDeposits CryptoDeposit[]
  bankConfig     AdminBankConfig?  @relation("AdminBankConfigToUser")
  bankDeposits   BankDeposit[]     @relation("UserBankDeposits")
  adminBankDeposits BankDeposit[]  @relation("AdminBankDeposits")
  ledgers        Ledger[]          @relation("UserLedger")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model Order {
  id            Int         @id @default(autoincrement())
  userId        Int
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedByAdminId Int?
  processingStartedAt DateTime?
  productLink   String
  productName   String      @default("")
  shopId        String?
  variant       String?
  quantity      Int
  phone         String
  address       String
  note          String?
  voucherCode   String?     @map("voucherType")
  voucherLabel  String?
  unitPrice     Int?
  total         Int
  status        OrderStatus @default(PENDING)
  cancelReason  String?
  spcCookie     String?     @default("")
  trackingNo    String?     @default("")
  shopeeTrackingData String? @default("")

  complaintReason String?
  complaintStatus String?   // "PENDING", "APPROVED", "REJECTED"
  complaintAt     DateTime?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model VoucherPricing {
  id            Int         @id @default(autoincrement())
  code          String      @unique @map("voucherType")
  label         String      @default("")
  unitPrice     Int
  isMaintenance Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Transaction {
  id        Int             @id @default(autoincrement())
  userId    Int
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  type      TransactionType
  note      String
  createdAt DateTime        @default(now())
  
  @@index([userId, createdAt])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  adminId    Int
  admin      User     @relation("AuditLogAdmin", fields: [adminId], references: [id], onDelete: Cascade)
  action     String
  targetType String
  targetId   Int
  details    String
  createdAt  DateTime @default(now())
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())
}

model SystemProxy {
  id        Int      @id @default(autoincrement())
  host      String
  port      Int
  username  String
  password  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([host, port, username, password])
}

model Withdrawal {
  id            Int               @id @default(autoincrement())
  userId        Int
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Int
  walletAddress String
  network       String            @default("BSC/BEP20")
  status        WithdrawalStatus  @default(PENDING)
  rejectReason  String?
  processedById Int?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model DeadLetterQueue {
  id        Int      @id @default(autoincrement())
  orderId   Int?
  payload   String?
  error     String   @default("")
  createdAt DateTime @default(now())
}

model CryptoDeposit {
  id             String              @id @default(uuid())
  userId         Int
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  network        String              // BSC or TRX
  address        String              // receiving wallet
  amount         Int                 // base request amount in USDT
  expectedAmount Float               // fractional amount to expect e.g., 5.123
  status         CryptoDepositStatus @default(PENDING)
  txId           String?             @unique
  expiresAt      DateTime
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model AdminBankConfig {
  id            String   @id @default(cuid())
  adminId       Int      @unique
  admin         User     @relation("AdminBankConfigToUser", fields: [adminId], references: [id], onDelete: Cascade)
  bankName      String
  accountNumber String
  accountName   String
  branch        String?
  contactInfo   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BankDeposit {
  id             String            @id @default(cuid())
  userId         Int
  user           User              @relation("UserBankDeposits", fields: [userId], references: [id], onDelete: Cascade)
  adminId        Int
  admin          User              @relation("AdminBankDeposits", fields: [adminId], references: [id], onDelete: Cascade)
  amount         Int               
  status         BankDepositStatus @default(PENDING)
  complaintImage String?
  expiresAt      DateTime
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model SystemAccount {
  id          String   @id // SYSTEM_REVENUE, SYSTEM_ESCROW
  name        String
  balance     Int      @default(0)
  ledgers     Ledger[] @relation("SystemLedger")
}

model JournalEntry {
  id          String   @id @default(cuid()) // Mã Bút Toán
  type        String   
  status      String   @default("BALANCED") 
  createdAt   DateTime @default(now())
  
  lines       Ledger[] @relation("JournalLedger")
}

model Ledger {
  id              String         @id @default(cuid())
  journalId       String
  journal         JournalEntry   @relation("JournalLedger", fields: [journalId], references: [id], onDelete: Cascade)
  
  userId          Int?
  user            User?          @relation("UserLedger", fields: [userId], references: [id], onDelete: Cascade)
  
  systemAccountId String?
  systemAccount   SystemAccount? @relation("SystemLedger", fields: [systemAccountId], references: [id], onDelete: Cascade)
  
  debit           Int            @default(0) // Số tiền ghi nợ
  credit          Int            @default(0) // Số tiền ghi có
  note            String?
  createdAt       DateTime       @default(now())

  @@index([userId, createdAt])
  @@index([systemAccountId, createdAt])
}
